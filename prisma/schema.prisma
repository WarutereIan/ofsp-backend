  totalOrders     Int
  uniqueFarmers   Int
  uniqueBuyers    Int
  revenue         Float?
  volume          Float?
  completedOrders Int
  averageOrderValue Float?

  @@map("daily_order_summary")
}

// Materialized View: Monthly Farmer Statistics
// Purpose: Monthly aggregations of farmer performance metrics for leaderboards and analytics
view MonthlyFarmerStatistics {
  month           DateTime @db.Date
  farmerId        String
  userId          String
  farmerName      String?
  subCounty       String?
  county          String?
  orderCount      Int
  revenue         Float?
  volume          Float?
  completedOrders Int
  averageRating   Float
  ratingCount     Int

  @@map("monthly_farmer_statistics")
}

// Materialized View: Center Utilization Summary
