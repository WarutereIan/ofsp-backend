  centerName      String?
  centerCode      String?
  county          String?
  subCounty       String?
  totalCapacity   Float?
  currentStock    Float?
  availableCapacity Float?
  utilizationRate Float?
  totalBatches    Int
  freshBatches    Int
  agingBatches    Int
  criticalBatches Int
  totalTransactions Int
  totalStockIn    Float?
  totalStockOut   Float?

  @@map("center_utilization_summary")
}

// Materialized View: Weekly Buyer Sourcing
// Purpose: Weekly buyer sourcing patterns and procurement metrics
view WeeklyBuyerSourcing {
  week                DateTime @db.Date
  buyerId             String
  userId              String
  buyerName           String?
  orderCount          Int
  uniqueSuppliers     Int
  procurementValue    Float?
  volumeSourced       Float?
  directOrders        Int
  rfqOrders           Int
  sourcingRequestOrders Int

  @@map("weekly_buyer_sourcing")
}

// ============================================
// OPTIMIZATION MATERIALIZED VIEWS
// ============================================

view PlatformMetricsSummary {
  date            DateTime @db.Date
  revenue         Float?
  volume          Float?
  totalOrders     Int
  completedOrders Int
  activeFarmers   Int
  activeBuyers    Int
  averagePrice    Float?
  platformFee     Float?

  @@map("platform_metrics_summary")
}

view FarmerLeaderboardMonthly {
  month           DateTime @db.Date
  farmerId        String
  farmerName      String?
  subCounty       String?
  county          String?
  revenue         Float?
  volume          Float?
  totalOrders     Int
  completedOrders Int
  averageRating   Float?
  ratingCount     Int

  @@map("farmer_leaderboard_monthly")
}

view MarketPriceSummary {
  week          DateTime @db.Date
  variety       String
  grade         String
  location      String
  averagePrice  Float?
  minPrice      Float?
  maxPrice      Float?
  listingCount  Int
  totalQuantity Float?

  @@map("market_price_summary")
}

view BuyerDemandSummary {
  week                DateTime @db.Date
  variety             String
  grade               String
  location            String
  totalBuyerCount     Int
  totalQuantityNeeded Float?
  sourceType          String   @map("source_type")

  @@map("buyer_demand_summary")
}

view UserGrowthSummary {
  month         DateTime @db.Date
  role          String
  county        String?
  subCounty     String?
  newUsers      Int
